---
import logoCream from '../assets/brand/otto-logo-cream.svg?raw';
import { NAV_LINKS, WHATSAPP_URL, STATUS_BADGE } from '../config';

// Links de seção (#âncora) só existem na home. Fora dela (ex.: página de case),
// prefixa com "/" para voltar à home e então rolar até a seção. Na home, mantém
// o "#âncora" puro para rolagem suave sem recarregar.
const isHome = Astro.url.pathname === '/';
const navHref = (href: string) => (isHome ? href : `/${href}`);
const logoHref = isHome ? '#top' : '/';
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href={logoHref} class="site-header__logo" aria-label="Otto Branding — início">
      <Fragment set:html={logoCream} />
    </a>

    {STATUS_BADGE && (
      <span class="status-badge" aria-label={`Status: ${STATUS_BADGE}`}>
        <span class="status-badge__dot" aria-hidden="true"></span>
        {STATUS_BADGE}
      </span>
    )}

    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />

    <nav class="site-header__nav" aria-label="Navegação principal">
      {NAV_LINKS.map((link) => (
        <a href={navHref(link.href)} class="site-header__link">{link.label}</a>
      ))}
      <a class="btn btn-whatsapp" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">
        Falar no WhatsApp
      </a>
    </nav>

    <label for="nav-toggle" class="nav-hamburger" aria-label="Abrir menu">
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </label>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgb(var(--otto-charcoal-rgb) / 0.8);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgb(var(--otto-offwhite-rgb) / 0.1);
    transform: translateZ(0);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding-block: var(--space-4);
  }

  .site-header__logo {
    display: inline-flex;
    width: 5.5rem;
    flex-shrink: 0;
  }

  .site-header__logo :global(svg) {
    width: 100%;
    height: auto;
  }

  /* Badge de status — ponto pulsante + rótulo em versalete */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(var(--otto-offwhite-rgb) / 0.72);
    padding: var(--space-1) var(--space-3);
    border: 1px solid rgb(var(--otto-offwhite-rgb) / 0.16);
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .status-badge__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: #37d67a;
    box-shadow: 0 0 0 0 rgb(55 214 122 / 0.55);
    animation: badge-pulse 2.4s var(--ease-standard) infinite;
  }

  @keyframes badge-pulse {
    0% { box-shadow: 0 0 0 0 rgb(55 214 122 / 0.5); }
    70% { box-shadow: 0 0 0 7px rgb(55 214 122 / 0); }
    100% { box-shadow: 0 0 0 0 rgb(55 214 122 / 0); }
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-left: auto;
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .site-header__link {
    color: rgb(var(--otto-offwhite-rgb) / 0.82);
    text-decoration: none;
    position: relative;
    padding-block: var(--space-1);
  }

  .site-header__link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 0;
    height: 1px;
    background-color: var(--otto-red);
    transition: right var(--duration-base) var(--ease-standard);
  }

  .site-header__link:hover {
    color: var(--otto-offwhite);
  }

  .site-header__link:hover::after {
    right: 0;
  }

  .btn-whatsapp {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    background-color: var(--otto-red);
    color: var(--otto-offwhite);
  }

  .btn-whatsapp:hover {
    transform: translateY(-1px);
    background-color: color-mix(in srgb, var(--otto-red) 88%, black);
  }

  /* Hamburger (só mobile) */
  .nav-hamburger {
    display: none;
    margin-left: auto;
    width: 44px;
    height: 44px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--otto-offwhite);
    transition: transform var(--duration-base) var(--ease-standard),
      opacity var(--duration-base) var(--ease-standard);
  }

  @media (max-width: 60rem) {
    .status-badge {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }

    .site-header__nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      margin-left: 0;
      padding: var(--space-3) var(--container-pad) var(--space-5);
      background-color: var(--otto-charcoal);
      -webkit-backdrop-filter: blur(14px);
      backdrop-filter: blur(14px);
      box-shadow: 0 24px 40px rgb(0 0 0 / 0.3);
      border-bottom: 1px solid rgb(var(--otto-offwhite-rgb) / 0.1);
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--duration-base) var(--ease-standard),
        transform var(--duration-base) var(--ease-standard);
    }

    .nav-toggle:checked ~ .site-header__nav {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .site-header__link {
      padding-block: var(--space-4);
      border-bottom: 1px solid rgb(var(--otto-offwhite-rgb) / 0.08);
      font-size: var(--text-md);
    }

    .btn-whatsapp {
      margin-top: var(--space-4);
      align-self: flex-start;
    }

    .nav-toggle:checked ~ .nav-hamburger span:first-child {
      transform: translateY(3.5px) rotate(45deg);
    }

    .nav-toggle:checked ~ .nav-hamburger span:last-child {
      transform: translateY(-3.5px) rotate(-45deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__link::after,
    .site-header__nav,
    .nav-hamburger span,
    .btn-whatsapp {
      transition: none;
    }
    .status-badge__dot {
      animation: none;
    }
  }
</style>
