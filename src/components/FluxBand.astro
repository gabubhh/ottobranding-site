---
/*
  Faixa estática tingida — usa um dos renders 3D da IDV como textura de fundo,
  tingida por CSS para a paleta Otto. Sem WebGL: é decorativa e fica atrás de
  um scrim forte (ex.: CTA final).
*/
interface Props {
  class?: string;
  texture?: string;
}
const { class: className = '', texture = 'otto-band' } = Astro.props;
---

<div class:list={['flux-band', className]} aria-hidden="true">
  <picture class="flux-band__img">
    <source srcset={`/textures/${texture}.avif`} type="image/avif" />
    <source srcset={`/textures/${texture}.webp`} type="image/webp" />
    <img src={`/textures/${texture}.webp`} alt="" width="688" height="280" loading="lazy" decoding="async" />
  </picture>
</div>

<style>
  .flux-band {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background-color: var(--otto-ink);
  }

  .flux-band__img {
    position: absolute;
    inset: 0;
    display: block;
  }

  .flux-band__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) brightness(0.82) contrast(1.12);
  }

  .flux-band__img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(60% 55% at 50% 40%, rgb(var(--otto-red-rgb) / 0.2), transparent 70%);
    mix-blend-mode: soft-light;
  }

  @media (prefers-reduced-motion: no-preference) {
    .flux-band__img::after {
      animation: flux-band-drift 22s ease-in-out infinite alternate;
    }
  }

  @keyframes flux-band-drift {
    from { transform: translate3d(-2%, 1%, 0) scale(1.03); }
    to { transform: translate3d(3%, -2%, 0) scale(1.07); }
  }
</style>
