---
/*
  Preloader de entrada — inspirado na referência Ashley, adaptado à IDV Otto.
  Duas fases, 100% CSS (sem GSAP/JS de animação):
   1) três linhas que constroem a promessa da marca (sobem em stagger e saem),
   2) um wipe vermelho revela o wordmark da Otto.
  Depois a camada some.

  Robustez:
   - Só aparece uma vez por sessão (guard em BaseLayout marca html.is-loaded).
   - prefers-reduced-motion: não anima — a camada nem aparece.
   - Sem JS a animação se completa sozinha (animation ... forwards) e some.
*/
import logoCream from '../assets/brand/otto-logo-cream.svg?raw';
---

<div class="preloader" aria-hidden="true">
  <div class="preloader__stage">
    <div class="preloader__words">
      <span class="preloader__word">Sua marca</span>
      <span class="preloader__word">em outro</span>
      <span class="preloader__word preloader__word--accent">patamar.</span>
    </div>

    <div class="preloader__brand">
      <span class="preloader__logo"><Fragment set:html={logoCream} /></span>
      <span class="preloader__wipe"></span>
    </div>
  </div>
</div>

<style>
  .preloader {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
    background-color: var(--otto-ink);
    animation: pl-out 0.6s var(--ease-out) 2.2s forwards;
  }

  @keyframes pl-out {
    to {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }
  }

  .preloader__stage {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 4.5rem;
  }

  /* --- fase 1: as três linhas --- */
  .preloader__words {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.1em;
  }

  .preloader__word {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    line-height: 1.05;
    white-space: nowrap;
    letter-spacing: var(--tracking-tight);
    color: rgb(var(--otto-offwhite-rgb) / 0.55);
    opacity: 0;
    transform: translateY(22px);
    animation: pl-word 1.9s var(--ease-out) forwards;
  }

  .preloader__word--accent {
    font-weight: 900;
    color: var(--otto-offwhite);
  }

  .preloader__word:nth-child(1) { animation-delay: 0.1s; }
  .preloader__word:nth-child(2) { animation-delay: 0.32s; }
  .preloader__word:nth-child(3) { animation-delay: 0.54s; }

  @keyframes pl-word {
    0% { opacity: 0; transform: translateY(22px); }
    24% { opacity: 1; transform: translateY(0); }
    58% { opacity: 1; transform: translateY(0); }
    76% { opacity: 0; transform: translateY(-22px); }
    100% { opacity: 0; transform: translateY(-22px); }
  }

  /* --- fase 2: o wordmark revelado pelo wipe --- */
  .preloader__brand {
    position: relative;
    display: inline-flex;
    padding: 0.4em 0.1em;
  }

  .preloader__logo {
    display: inline-flex;
    width: clamp(6rem, 16vw, 8.5rem);
    opacity: 0;
    animation: pl-logo-in 0.3s var(--ease-out) 1.95s forwards;
  }

  .preloader__logo :global(svg) {
    width: 100%;
    height: auto;
  }

  @keyframes pl-logo-in {
    to { opacity: 1; }
  }

  .preloader__wipe {
    position: absolute;
    inset: 0;
    background-color: var(--otto-red);
    transform: scaleX(0);
    transform-origin: left center;
    animation: pl-wipe 0.9s var(--ease-out) 1.55s forwards;
  }

  @keyframes pl-wipe {
    0% { transform: scaleX(0); transform-origin: left center; }
    45% { transform: scaleX(1); transform-origin: left center; }
    46% { transform: scaleX(1); transform-origin: right center; }
    100% { transform: scaleX(0); transform-origin: right center; }
  }

  /* não repete na mesma sessão; nem aparece sob movimento reduzido */
  :global(html.is-loaded) .preloader {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .preloader {
      display: none;
    }
  }
</style>
