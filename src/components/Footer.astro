---
import logoCream from '../assets/brand/otto-logo-cream.svg?raw';

const year = new Date().getFullYear();
/* TODO: substituir pelo número real antes de publicar. */
const whatsappHref = 'https://wa.me/5500000000000';
---

<footer class="site-footer" id="contato">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <span class="site-footer__logo">
        <Fragment set:html={logoCream} />
      </span>
      <p class="site-footer__copy">© {year} Otto Branding. Todos os direitos reservados.</p>
    </div>

    <a class="btn btn-primary" href={whatsappHref} target="_blank" rel="noopener noreferrer">
      Fale no WhatsApp
    </a>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding-block: var(--space-8);
  }

  .site-footer__brand {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .site-footer__logo {
    display: inline-flex;
    width: 3rem;
    flex-shrink: 0;
  }

  .site-footer__logo :global(svg) {
    width: 100%;
    height: auto;
  }

  .site-footer__copy {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }
</style>
