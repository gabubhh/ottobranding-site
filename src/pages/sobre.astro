---
/*
  Página de entidade. Existe para dar ao Gabriel e à Otto uma URL própria e
  consistente com o que Instagram, LinkedIn e diretórios vão dizer — é a
  consistência entre essas fontes que faz um modelo tratar "Otto Branding"
  como uma entidade real em vez de um nome solto.

  É aqui que Recife entra no corpo do texto: quem chega nesta página já
  buscou, e agora quer confirmar que a Otto é gente de verdade.
*/
import BaseLayout from '../layouts/BaseLayout.astro';
import { patamares } from '../data/metodo';
import { SITE_URL, DIAGNOSTIC_URL, INSTAGRAM_URL } from '../config';
import { PERSON_ID, breadcrumb, faqSchema, type Faq } from '../data/schema';

const faqs: Faq[] = [
  {
    q: 'A Otto atende fora de Recife?',
    a: [
      'Sim. A Otto atende clientes em todo o Brasil, com projetos 100% remotos.',
      'O estúdio é sediado em Recife, mas nenhuma etapa do processo depende de presença física: imersão, apresentações e aprovações acontecem por videochamada, e as entregas são digitais.',
      'Hoje há clientes atendidos dentro e fora de Pernambuco, e o processo é o mesmo nos dois casos.',
    ],
  },
  {
    q: 'Quem executa os projetos da Otto?',
    a: [
      'Gabriel Araújo conduz todos os projetos, do diagnóstico à entrega final.',
      'A Otto é um estúdio, não uma agência: você fala com quem desenha e decide, sem camada de atendimento no meio.',
      'Quando o escopo pede especialista — fotografia, motion, desenvolvimento —, a Otto traz parceiros e segue responsável pela direção.',
    ],
  },
  {
    q: 'Por onde começa um projeto com a Otto?',
    a: [
      'Todo projeto começa pelo diagnóstico de marca, sem exceção.',
      'É o diagnóstico que revela se o problema é de posicionamento, de identidade ou de aplicação — e é ele que define o escopo antes de qualquer proposta.',
      'Sem essa etapa, o projeto vira execução de pedido, e execução de pedido não muda o critério pelo qual o cliente escolhe.',
    ],
  },
];

const schema = [
  {
    '@type': 'AboutPage',
    name: 'Sobre a Otto Branding',
    url: `${SITE_URL}/sobre`,
    mainEntity: { '@id': PERSON_ID },
  },
  faqSchema(faqs),
  breadcrumb([{ name: 'Sobre', path: '/sobre' }]),
];
---

<BaseLayout
  title="Sobre a Otto Branding e Gabriel Araújo | Estúdio de branding"
  description="A Otto Branding é um estúdio de branding e identidade visual dirigido por Gabriel Araújo. Estratégia antes de estética, com atendimento remoto em todo o Brasil."
  schema={schema}
>
  <section class="ahero">
    <div class="ahero__glow" aria-hidden="true"></div>
    <div class="container ahero__inner">
      <p class="eyebrow rise" style="--rise-delay: 60ms">Sobre</p>
      <h1 class="ahero__title rise" style="--rise-delay: 140ms">
        Nascemos para tirar marcas do <span class="t-em">lugar comum</span>.
      </h1>
      <p class="ahero__lead rise" style="--rise-delay: 240ms">
        A Otto Branding é um estúdio de branding, posicionamento e identidade
        visual dirigido por Gabriel Araújo. Sediado em Recife, com atendimento
        remoto em todo o Brasil.
      </p>
    </div>
  </section>

  <section class="section quem" data-surface="light">
    <div class="container quem__grid">
      <figure class="quem__photo reveal">
        <img
          src="/sobre/gabriel.webp"
          alt="Gabriel Araújo, diretor de arte e estrategista de marca à frente da Otto Branding"
          width="1086"
          height="1448"
          loading="eager"
          decoding="async"
        />
        <figcaption>Gabriel Araújo, diretor de arte e estrategista de marca</figcaption>
      </figure>

      <div class="quem__text">
        <h2 class="quem__title reveal">Quem conduz</h2>
        <div class="quem__body reveal">
          <p>
            <strong>Gabriel Araújo</strong> é diretor de arte e estrategista de
            marca. São cinco anos construindo marcas que precisam sustentar mais
            valor do que o mercado espera delas — em beleza, turismo, serviços e
            varejo.
          </p>
          <p>
            A Otto nasceu de uma constatação simples e incômoda: a maior parte
            dos negócios que perde para o concorrente mais barato não perde por
            qualidade. Perde porque a marca não conta o valor que o trabalho já
            tem. Design bonito não resolve isso. Posicionamento resolve.
          </p>
          <p>
            Por isso todo projeto começa por diagnóstico, e nenhuma decisão
            visual acontece antes de estar claro que espaço a marca vai defender.
            É mais lento no começo e mais barato no fim.
          </p>
        </div>
        <blockquote class="quem__quote reveal">
          Marca forte não é a mais criativa. É a que ocupa um espaço que nenhum
          concorrente consegue defender.
        </blockquote>
        <p class="quem__social reveal">
          <a class="link-arrow" href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer">
            <span class="link-arrow__icon" aria-hidden="true">→</span>
            <span class="link-arrow__label">Instagram da Otto</span>
          </a>
        </p>
      </div>
    </div>
  </section>

  <section class="section como">
    <div class="container como__inner">
      <h2 class="como__title reveal">Como trabalhamos</h2>
      <p class="como__lead reveal">
        O Método Otto organiza a construção de marca em três patamares. Cada um
        resolve uma pergunta antes de passar para o próximo. Estratégia antes de
        estética, sempre.
      </p>
      <ol class="patamares reveal-group">
        {patamares.map((p, i) => (
          <li class="patamar reveal" style={`--reveal-index: ${i}`}>
            <span class="patamar__n">{p.n}</span>
            <div>
              <h3 class="patamar__name">Patamar {p.n.replace('0', '')}. {p.name}.</h3>
              <p class="patamar__text">{p.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section afaq" data-surface="light">
    <div class="container afaq__inner">
      <h2 class="afaq__title reveal">Perguntas frequentes</h2>
      <div class="afaq__list">
        {faqs.map((f) => (
          <div class="afaq__item reveal">
            <h3 class="afaq__q">{f.q}</h3>
            {f.a.map((p) => (
              <p class="afaq__a">{p}</p>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section acta">
    <div class="container acta__content">
      <h2 class="acta__headline reveal">Vamos ver onde sua marca está perdendo valor?</h2>
      <a class="btn btn-primary reveal" href={DIAGNOSTIC_URL} target="_blank" rel="noopener noreferrer">
        Começar pelo diagnóstico
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .ahero {
    position: relative;
    overflow: hidden;
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    padding-block: var(--space-9);
  }

  .ahero__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(58% 68% at 85% 0%, rgb(var(--otto-red-rgb) / 0.15), transparent 62%);
  }

  .ahero__inner {
    position: relative;
    max-width: 42rem;
  }

  .ahero__title {
    margin-top: var(--space-4);
    font-size: clamp(2.1rem, 3.4vw + 1rem, 3.4rem);
    letter-spacing: var(--tracking-tighter);
    line-height: 1.05;
    text-wrap: balance;
  }

  .ahero__lead {
    margin-top: var(--space-5);
    max-width: 36rem;
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: rgb(var(--otto-offwhite-rgb) / 0.8);
  }

  /* ===================== QUEM ===================== */
  .quem__grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: var(--space-8);
    align-items: start;
  }

  .quem__photo {
    margin: 0;
  }

  .quem__photo img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-md);
    background-color: rgb(36 36 36 / 0.05);
  }

  .quem__photo figcaption {
    margin-top: var(--space-3);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .quem__title,
  .como__title,
  .afaq__title {
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-5);
  }

  .quem__body p {
    line-height: var(--leading-relaxed);
    max-width: 40rem;
  }

  .quem__body p + p {
    margin-top: var(--space-4);
  }

  .quem__quote {
    margin: var(--space-6) 0 0;
    padding-left: var(--space-5);
    border-left: 2px solid var(--otto-red);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    max-width: 32ch;
  }

  .quem__social {
    margin-top: var(--space-6);
    font-size: var(--text-sm);
  }

  /* ===================== COMO ===================== */
  .como {
    background-color: var(--otto-charcoal);
    color: var(--otto-offwhite);
  }

  .como__inner {
    max-width: 46rem;
  }

  .como__lead {
    margin-bottom: var(--space-7);
    color: rgb(var(--otto-offwhite-rgb) / 0.74);
    line-height: var(--leading-relaxed);
  }

  .patamares {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  .patamar {
    display: flex;
    gap: var(--space-5);
    padding: var(--space-5);
    border: 1px solid rgb(var(--otto-offwhite-rgb) / 0.12);
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, rgb(var(--otto-offwhite-rgb) / 0.04), transparent 60%);
  }

  .patamar__n {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--text-lg);
    line-height: 1.2;
    color: var(--otto-red);
    flex-shrink: 0;
  }

  .patamar__name {
    font-size: var(--text-md);
    letter-spacing: var(--tracking-tight);
  }

  .patamar__text {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: rgb(var(--otto-offwhite-rgb) / 0.7);
  }

  /* ===================== FAQ ====================== */
  .afaq__inner {
    max-width: 46rem;
  }

  .afaq__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }

  .afaq__item {
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .afaq__q {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-4);
  }

  .afaq__a {
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  .afaq__a:first-of-type {
    color: var(--color-text);
  }

  .afaq__a + .afaq__a {
    margin-top: var(--space-4);
  }

  /* ===================== CTA ====================== */
  .acta {
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    text-align: center;
  }

  .acta__content {
    max-width: 34rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .acta__headline {
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-tighter);
    line-height: var(--leading-tight);
    text-wrap: balance;
  }

  @media (max-width: 60rem) {
    .quem__grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .quem__photo {
      max-width: 20rem;
    }
  }
</style>
