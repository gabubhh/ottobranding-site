---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignatureFlux from '../components/SignatureFlux.astro';
import { WHATSAPP_URL, DIAGNOSTIC_URL } from '../config';

// Soluções — títulos reais do documento de copy. Sem descritores inventados:
// o parêntese ("entrada paga") é o único que o doc fornece.
const solucoes = [
  { title: 'Diagnóstico de marca', tag: 'entrada paga' },
  { title: 'Posicionamento e plataforma de marca', tag: '' },
  { title: 'Identidade visual e verbal', tag: '' },
  { title: 'Presença visual contínua', tag: '' },
];

// Método Otto — três patamares (copy real do doc). A numeração aqui É
// informação: patamar = degrau, e cada um precede o próximo.
const patamares = [
  {
    n: '01',
    name: 'Clareza',
    text: 'Quem a marca é, para quem existe, que espaço ela ocupa. Diagnóstico e posicionamento.',
  },
  {
    n: '02',
    name: 'Direção',
    text: 'As decisões que guiam tudo: plataforma de marca, estratégia verbal e visual.',
  },
  {
    n: '03',
    name: 'Sistema',
    text: 'A marca construída e consistente: identidade e aplicação.',
  },
];
---

<BaseLayout title="Otto Branding — Criamos marcas de Otto Patamar">
  <!-- ============================ HERO ============================ -->
  <section class="hero">
    <SignatureFlux class="hero__flux" texture="otto-flux" />
    <div class="hero__scrim" aria-hidden="true"></div>

    <div class="container hero__container">
     <div class="hero__content">
      <p class="eyebrow rise" style="--rise-delay: 60ms">Estratégia · Posicionamento · Identidade</p>
      <h1 class="hero__headline rise" style="--rise-delay: 140ms">
        A maioria das marcas compete por preço.
        <span class="hero__headline-accent">As fortes constroem preferência.</span>
      </h1>
      <p class="hero__descritor rise" style="--rise-delay: 240ms">
        A Otto une estratégia e design para tirar sua marca do lugar comum e
        colocá-la em outro patamar de percepção de valor.
      </p>
      <p class="hero__signature rise" style="--rise-delay: 320ms">Criamos marcas de <em>Otto Patamar</em>.</p>
      <div class="hero__actions rise" style="--rise-delay: 400ms">
        <a class="btn btn-primary" href={DIAGNOSTIC_URL}>Começar pelo diagnóstico</a>
        <a class="link-arrow hero__whats" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">
          <span class="link-arrow__icon" aria-hidden="true">→</span>
          <span class="link-arrow__label">Falar no WhatsApp</span>
        </a>
      </div>
     </div>
    </div>
  </section>

  <!-- ========================== SOLUÇÕES ========================== -->
  <section id="solucoes" class="section solucoes" data-surface="light">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Soluções</p>
        <h2 class="section-title reveal">
          Tudo que sua marca precisa para sair do lugar comum.
        </h2>
      </div>

      <ul class="solucoes__list reveal-group">
        {solucoes.map((item, i) => (
          <li class="solucoes__row reveal" style={`--reveal-index: ${i}`}>
            <span class="solucoes__title">{item.title}</span>
            {item.tag && <span class="solucoes__tag">{item.tag}</span>}
            <span class="solucoes__arrow" aria-hidden="true">→</span>
          </li>
        ))}
      </ul>

      <p class="solucoes__cta reveal">
        Pronto para começar?
        <a class="link-arrow" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">
          <span class="link-arrow__icon" aria-hidden="true">→</span>
          <span class="link-arrow__label">Fale com a gente</span>
        </a>
      </p>
    </div>
  </section>

  <!-- =========================== MÉTODO =========================== -->
  <section id="metodo" class="section metodo">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Método Otto</p>
        <h2 class="section-title reveal">
          Sem achismo. Um caminho claro, do diagnóstico ao patamar.
        </h2>
        <p class="section-lead reveal">
          O Método Otto organiza a construção de marca em três patamares. Cada um
          resolve uma pergunta antes de passar para o próximo. Estratégia antes de
          estética, sempre.
        </p>
        <!-- TODO (conteúdo, não design): fechar nome e sigla do método (timebox 1h). -->
      </div>

      <ol class="patamares reveal-group">
        {patamares.map((p, i) => (
          <li class="patamar reveal" style={`--reveal-index: ${i}; --step: ${i}`}>
            <span class="patamar__n">{p.n}</span>
            <div class="patamar__body">
              <h3 class="patamar__name">Patamar {p.n.replace('0', '')}. {p.name}.</h3>
              <p class="patamar__text">{p.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- =========================== SOBRE ============================ -->
  <section id="sobre" class="section sobre" data-surface="light">
    <div class="container sobre__grid">
      <div class="sobre__head">
        <p class="eyebrow reveal">Sobre</p>
        <h2 class="section-title reveal">Nascemos para tirar marcas do lugar comum.</h2>
      </div>
      <div class="sobre__body reveal">
        <p>
          A Otto é dirigida por <strong>Gabriel Araújo</strong>, diretor de arte e
          estrategista de marca. Cinco anos construindo marcas que precisam sustentar
          mais valor do que o mercado espera delas.
        </p>
        <blockquote class="sobre__quote">
          Marca forte não é a mais criativa. É a que ocupa um espaço que nenhum
          concorrente consegue defender.
        </blockquote>
      </div>
    </div>
  </section>

  <!-- =========================== CASES ============================ -->
  <section id="cases" class="section cases">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Cases</p>
        <h2 class="section-title reveal">Marcas de Otto Patamar.</h2>
      </div>

      <div class="cases__grid reveal-group">
        <!-- Card real: leva à página modelo, marcado como exemplo de layout -->
        <a class="case-card case-card--model reveal" href="/case-modelo" style="--reveal-index: 0">
          <span class="case-card__badge">Exemplo de layout</span>
          <span class="case-card__thumb" aria-hidden="true"></span>
          <span class="case-card__name">Página de case modelo</span>
          <span class="case-card__meta">Veja como um case aparece →</span>
        </a>

        <!-- Slots de case a publicar (candidatos do doc), claramente marcados -->
        <div class="case-card case-card--empty reveal" style="--reveal-index: 1" aria-hidden="true">
          <span class="case-card__thumb"></span>
          <span class="case-card__name">Therapy and Beauty</span>
          <span class="case-card__meta">[Case a publicar]</span>
        </div>
        <div class="case-card case-card--empty reveal" style="--reveal-index: 2" aria-hidden="true">
          <span class="case-card__thumb"></span>
          <span class="case-card__name">Astros Barbearia</span>
          <span class="case-card__meta">[Case a publicar]</span>
        </div>
      </div>

      <p class="cases__note reveal">
        <strong>Nota (conteúdo, não layout):</strong> os cases reais entram quando
        houver resultado com número. Até lá, a estrutura está pronta — veja a
        <a href="/case-modelo">página de case modelo</a> para o formato de aprovação.
      </p>
    </div>
  </section>

  <!-- ========================= DEPOIMENTOS ======================== -->
  <section id="depoimentos" class="section depoimentos" data-surface="light">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Depoimentos</p>
        <h2 class="section-title reveal">Histórias reais, com resultado real.</h2>
      </div>

      <div class="depoimentos__grid reveal-group">
        {[0, 1, 2].map((i) => (
          <figure class="depoimento depoimento--empty reveal" style={`--reveal-index: ${i}`}>
            <blockquote>[Depoimento a coletar]</blockquote>
            <figcaption>
              Peça na entrega do próximo projeto — citando o <em>resultado</em>
              (“aumentou X”, “fechou Y”), não o processo.
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ========================= CTA FINAL ========================== -->
  <section class="section cta-final">
    <SignatureFlux class="cta-final__flux" texture="otto-band" />
    <div class="cta-final__scrim" aria-hidden="true"></div>
    <div class="container cta-final__content">
      <h2 class="cta-final__headline reveal">
        Sua marca está sendo escolhida ou apenas comparada?
      </h2>
      <p class="cta-final__sub reveal">
        O diagnóstico mostra onde ela perde valor e o que precisa mudar.
      </p>
      <a class="btn btn-primary cta-final__btn reveal" href={DIAGNOSTIC_URL}>
        Começar pelo diagnóstico
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================ HERO ============================ */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: min(88vh, 820px);
    padding-block: var(--space-8);
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    overflow: hidden;
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        100deg,
        rgb(var(--otto-ink-rgb) / 0.95) 0%,
        rgb(var(--otto-ink-rgb) / 0.7) 34%,
        rgb(var(--otto-ink-rgb) / 0.15) 62%,
        transparent 100%
      ),
      linear-gradient(to top, rgb(var(--otto-ink-rgb) / 0.9), transparent 40%);
  }

  .hero__container {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .hero__content {
    max-width: 42rem;
  }

  .hero__headline {
    margin-top: var(--space-4);
    /* headline longa: cap menor que o --text-2xl para caber com o CTA acima
       da dobra em telas de notebook */
    font-size: clamp(2.25rem, 4.2vw + 0.9rem, 3.5rem);
    letter-spacing: var(--tracking-tight);
    line-height: 1.08;
    text-wrap: balance;
  }

  .hero__headline-accent {
    color: var(--otto-offwhite);
    display: block;
  }

  .hero__descritor {
    margin-top: var(--space-5);
    max-width: 34rem;
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: rgb(var(--otto-offwhite-rgb) / 0.78);
  }

  .hero__signature {
    margin-top: var(--space-5);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-tight);
  }

  .hero__signature em {
    font-style: normal;
    font-weight: 900;
    color: var(--otto-red);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-5);
    margin-top: var(--space-6);
  }

  .hero__whats {
    color: var(--otto-offwhite);
  }

  /* ===================== CABEÇALHOS DE SEÇÃO ==================== */
  .section-head {
    max-width: 40rem;
    margin-bottom: var(--space-8);
  }

  .section-title {
    margin-top: var(--space-4);
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-snug);
    text-wrap: balance;
  }

  .section-lead {
    margin-top: var(--space-5);
    max-width: 38rem;
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  /* ========================== SOLUÇÕES ========================= */
  .solucoes__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }

  .solucoes__row {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding-block: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .solucoes__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-tight);
    transition: transform var(--duration-base) var(--ease-out);
  }

  .solucoes__tag {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--otto-red);
    border: 1px solid color-mix(in srgb, var(--otto-red) 40%, transparent);
    padding: 0.15em 0.6em;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .solucoes__arrow {
    margin-left: auto;
    color: var(--color-text-secondary);
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out),
      color var(--duration-base) var(--ease-out);
  }

  .solucoes__row:hover .solucoes__title {
    transform: translateX(8px);
  }

  .solucoes__row:hover .solucoes__arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--otto-red);
  }

  .solucoes__cta {
    margin-top: var(--space-7);
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: baseline;
  }

  /* =========================== MÉTODO ========================== */
  .metodo {
    background-color: var(--otto-charcoal);
    color: var(--otto-offwhite);
  }

  .patamares {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }

  .patamar {
    display: flex;
    gap: var(--space-5);
    padding: var(--space-6);
    /* deslocamento ascendente: cada patamar sobe um degrau (a numeração é
       informação — são degraus que se sucedem) */
    margin-left: calc(var(--step) * clamp(0rem, 4vw, 3rem));
    border: 1px solid rgb(var(--otto-offwhite-rgb) / 0.12);
    border-radius: var(--radius-md);
    background: linear-gradient(
      135deg,
      rgb(var(--otto-offwhite-rgb) / 0.04),
      transparent 60%
    );
    transition: border-color var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }

  .patamar:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--otto-red) 55%, transparent);
  }

  .patamar__n {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--text-xl);
    line-height: 1;
    color: var(--otto-red);
    flex-shrink: 0;
  }

  .patamar__name {
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-tight);
  }

  .patamar__text {
    margin-top: var(--space-2);
    max-width: 44ch;
    color: rgb(var(--otto-offwhite-rgb) / 0.74);
  }

  /* =========================== SOBRE =========================== */
  .sobre__grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-8);
    align-items: start;
  }

  .sobre__body p {
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
  }

  .sobre__quote {
    margin: var(--space-6) 0 0;
    padding-left: var(--space-5);
    border-left: 2px solid var(--otto-red);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
  }

  /* =========================== CASES =========================== */
  .cases {
    background-color: var(--otto-charcoal);
    color: var(--otto-offwhite);
  }

  .cases__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .case-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-4);
    border: 1px solid rgb(var(--otto-offwhite-rgb) / 0.12);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    position: relative;
    isolation: isolate;
  }

  .case-card__thumb {
    display: block;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-sm);
    background:
      radial-gradient(120% 120% at 70% 20%, rgb(var(--otto-red-rgb) / 0.18), transparent 60%),
      linear-gradient(160deg, #2f2f2f, var(--otto-ink));
    margin-bottom: var(--space-4);
  }

  .case-card__badge {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    z-index: 1;
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    background-color: var(--otto-red);
    color: var(--otto-offwhite);
    padding: 0.2em 0.6em;
    border-radius: var(--radius-full);
  }

  .case-card__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-tight);
  }

  .case-card__meta {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .case-card--model {
    transition: transform var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out);
  }

  .case-card--model:hover {
    transform: translateY(-4px);
    border-color: var(--otto-red);
  }

  .case-card--empty {
    border-style: dashed;
    opacity: 0.5;
  }

  .cases__note {
    margin-top: var(--space-7);
    max-width: 46rem;
    font-size: var(--text-sm);
    color: rgb(var(--otto-offwhite-rgb) / 0.7);
  }

  .cases__note a {
    color: var(--otto-red-text-on-dark, #f0575a);
  }

  /* ======================== DEPOIMENTOS ======================== */
  .depoimentos__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .depoimento {
    margin: 0;
    padding: var(--space-6);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
  }

  .depoimento blockquote {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-secondary);
  }

  .depoimento figcaption {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
  }

  /* ========================= CTA FINAL ========================= */
  .cta-final {
    position: relative;
    overflow: hidden;
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    text-align: center;
  }

  .cta-final__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(
      90% 130% at 50% 40%,
      rgb(var(--otto-ink-rgb) / 0.55),
      rgb(var(--otto-ink-rgb) / 0.92) 75%
    );
  }

  .cta-final__content {
    position: relative;
    z-index: 2;
    max-width: 40rem;
    margin-inline: auto;
  }

  .cta-final__headline {
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-tighter);
    line-height: var(--leading-tight);
    text-wrap: balance;
  }

  .cta-final__sub {
    margin-top: var(--space-5);
    font-size: var(--text-md);
    color: rgb(var(--otto-offwhite-rgb) / 0.78);
  }

  .cta-final__btn {
    margin-top: var(--space-7);
  }

  /* ========================= RESPONSIVO ======================== */
  @media (max-width: 60rem) {
    .sobre__grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .cases__grid,
    .depoimentos__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 40rem) {
    .cases__grid,
    .depoimentos__grid {
      grid-template-columns: 1fr;
    }
    .patamar {
      margin-left: 0;
      padding: var(--space-5);
    }
    .solucoes__arrow {
      display: none;
    }
  }
</style>
