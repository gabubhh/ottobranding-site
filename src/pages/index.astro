---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVideo from '../components/HeroVideo.astro';
import FluxBand from '../components/FluxBand.astro';
import { cases } from '../data/cases';
import { WHATSAPP_URL, DIAGNOSTIC_URL } from '../config';

// Soluções — formato da referência (Farda): nome + descrição. Descrições
// escritas na voz da Otto (direta, estratégica, "território", "patamar").
// Ordem em funil: diagnóstico → estratégia → construção → ativação.
const solucoes = [
  {
    title: 'Diagnóstico de marca',
    desc: 'O ponto de partida. Um raio-x do posicionamento que revela onde a marca perde valor e o que precisa mudar — antes de qualquer decisão visual.',
  },
  {
    title: 'Estratégia de marca',
    desc: 'Os fundamentos que orientam tudo: mercado, público, diferenciação e o território que a marca vai defender. A base de cada decisão.',
  },
  {
    title: 'Branding',
    desc: 'A construção da marca do princípio — estratégia, narrativa e identidade conectadas num sistema coeso, pronto para crescer com direção.',
  },
  {
    title: 'Rebranding',
    desc: 'Quando o negócio evolui, a percepção precisa acompanhar. Reposicionamos e reconstruímos a marca para refletir o que ela já é.',
  },
  {
    title: 'Identidade visual',
    desc: 'O rosto da marca. Logo, sistema gráfico e diretrizes que traduzem o posicionamento em algo reconhecível e consistente.',
  },
  {
    title: 'Web design',
    desc: 'O site como experiência de marca. Estrutura, narrativa e design que transformam posicionamento em percepção de valor e em oportunidade.',
  },
  {
    title: 'Motion',
    desc: 'Movimento a serviço da marca. Animação que amplia a percepção, apresenta conceitos e dá presença em cada canal.',
  },
  {
    title: 'Gestão de redes sociais',
    desc: 'Presença visual contínua. Direção criativa constante para manter a marca consistente e viva enquanto o negócio cresce.',
  },
];

// Método Otto — três patamares (copy real do doc). A numeração aqui É
// informação: patamar = degrau, e cada um precede o próximo.
const patamares = [
  { n: '01', name: 'Clareza', text: 'Quem a marca é, para quem existe, que espaço ela ocupa. Diagnóstico e posicionamento.' },
  { n: '02', name: 'Direção', text: 'As decisões que guiam tudo: plataforma de marca, estratégia verbal e visual.' },
  { n: '03', name: 'Sistema', text: 'A marca construída e consistente: identidade e aplicação.' },
];

// Cases — dados reais em src/data/cases.ts (cada card leva à página do case).

// Depoimentos — slider central (referência Ashley adaptada). Conteúdo é
// EXEMPLO na voz da Otto (foco em resultado/percepção). Atribuição fica em
// placeholder até coletar os reais — flag abaixo deixa isso explícito.
// photo: caminho da foto do cliente (ex.: '/depoimentos/fulano.jpg'). Vazio =
// mostra o avatar placeholder (silhueta). Trocar pelas fotos reais depois.
const reviews = [
  {
    quote: 'Paramos de ser cobrados só pelo preço. Hoje a conversa começa pelo valor — e a margem acompanhou.',
    name: '[Nome do cliente]',
    role: '[Empresa · Segmento]',
    photo: '',
  },
  {
    quote: 'A marca finalmente parece do tamanho da ambição do negócio. Passamos a receber propostas que antes nem chegavam até nós.',
    name: '[Nome do cliente]',
    role: '[Empresa · Segmento]',
    photo: '',
  },
  {
    quote: 'O reposicionamento deu clareza para a equipe inteira. Todo mundo passou a defender a mesma história.',
    name: '[Nome do cliente]',
    role: '[Empresa · Segmento]',
    photo: '',
  },
];
---

<BaseLayout title="Otto Branding — Criamos marcas de Otto Patamar">
  <!-- ============================ HERO ============================ -->
  <section class="hero">
    <HeroVideo class="hero__flux" />
    <div class="hero__scrim" aria-hidden="true"></div>

    <div class="container hero__container">
      <div class="hero__content">
        <p class="eyebrow rise" style="--rise-delay: 60ms">Estratégia · Posicionamento · Identidade</p>
        <h1 class="hero__headline rise" style="--rise-delay: 140ms">
          <span class="hero__headline-quiet">A maioria das marcas compete por preço.</span>
          <span class="hero__headline-accent">As fortes constroem <em>preferência</em>.</span>
        </h1>
        <p class="hero__descritor rise" style="--rise-delay: 240ms">
          A Otto une estratégia e design para tirar sua marca do lugar comum e
          colocá-la em outro patamar de percepção de valor.
        </p>
        <p class="hero__signature rise" style="--rise-delay: 320ms">Criamos marcas de <em>Otto Patamar</em>.</p>
        <div class="hero__actions rise" style="--rise-delay: 400ms">
          <a class="btn btn-primary" href={DIAGNOSTIC_URL} target="_blank" rel="noopener noreferrer">Começar pelo diagnóstico</a>
          <a class="link-arrow hero__whats" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">
            <span class="link-arrow__icon" aria-hidden="true">→</span>
            <span class="link-arrow__label">Falar no WhatsApp</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================== SOLUÇÕES ========================== -->
  <section id="solucoes" class="section solucoes" data-surface="light">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Soluções</p>
        <h2 class="section-title reveal">
          Tudo que sua marca precisa para <span class="t-em">sair do lugar comum</span>.
        </h2>
      </div>

      <ul class="solucoes__list reveal-group">
        {solucoes.map((item, i) => (
          <li class="solucao reveal" style={`--reveal-index: ${i}`}>
            <div class="solucao__head">
              <span class="solucao__arrow" aria-hidden="true">→</span>
              <h3 class="solucao__name">{item.title}</h3>
            </div>
            <p class="solucao__desc">{item.desc}</p>
          </li>
        ))}
      </ul>

      <p class="solucoes__cta reveal">
        Pronto para começar?
        <a class="link-arrow" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">
          <span class="link-arrow__icon" aria-hidden="true">→</span>
          <span class="link-arrow__label">Fale com a gente</span>
        </a>
      </p>
    </div>
  </section>

  <!-- =========================== MÉTODO =========================== -->
  <section id="metodo" class="section metodo">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Método Otto</p>
        <h2 class="section-title reveal">
          Sem achismo. Um caminho claro, do diagnóstico ao <span class="t-em">patamar</span>.
        </h2>
        <p class="section-lead reveal">
          O Método Otto organiza a construção de marca em três patamares. Cada um
          resolve uma pergunta antes de passar para o próximo. Estratégia antes de
          estética, sempre.
        </p>
        <!-- TODO (conteúdo, não design): fechar nome e sigla do método (timebox 1h). -->
      </div>

      <ol class="patamares reveal-group">
        {patamares.map((p, i) => (
          <li class="patamar reveal" style={`--reveal-index: ${i}; --step: ${i}`}>
            <span class="patamar__n">{p.n}</span>
            <div class="patamar__body">
              <h3 class="patamar__name">Patamar {p.n.replace('0', '')}. {p.name}.</h3>
              <p class="patamar__text">{p.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- =========================== SOBRE ============================ -->
  <section id="sobre" class="section sobre" data-surface="light">
    <div class="container sobre__grid">
      <figure class="sobre__photo reveal" aria-label="Foto de Gabriel Araújo (a inserir)">
        <span class="sobre__photo-note">[Sua foto aqui]</span>
      </figure>
      <div class="sobre__text">
        <p class="eyebrow reveal">Sobre</p>
        <h2 class="section-title reveal">Nascemos para tirar marcas do <span class="t-em">lugar comum</span>.</h2>
        <div class="sobre__body reveal">
          <p>
            A Otto é dirigida por <strong>Gabriel Araújo</strong>, diretor de arte e
            estrategista de marca. Cinco anos construindo marcas que precisam sustentar
            mais valor do que o mercado espera delas.
          </p>
          <blockquote class="sobre__quote">
            Marca forte não é a mais criativa. É a que ocupa um espaço que nenhum
            concorrente consegue defender.
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================== CASES ============================ -->
  <section id="cases" class="section cases">
    <div class="container">
      <div class="cases__head">
        <div class="section-head cases__head-text">
          <p class="eyebrow reveal">Cases</p>
          <h2 class="section-title reveal">Marcas de <span class="t-em">Otto Patamar</span>.</h2>
        </div>
        <div class="cases__controls reveal" aria-hidden="true">
          <button class="cases__arrow-btn" data-cases-prev type="button" aria-label="Case anterior">
            <span aria-hidden="true">←</span>
          </button>
          <button class="cases__arrow-btn" data-cases-next type="button" aria-label="Próximo case">
            <span aria-hidden="true">→</span>
          </button>
        </div>
      </div>
    </div>

    <div class="cases__viewport">
      <div class="container">
        <ul class="cases__track" data-cases-track>
          {cases.map((c, i) => (
            <li class="case-slide">
              <a class="case-card case-card--model" href={`/cases/${c.slug}`}>
                <span class="case-card__media">
                  <img
                    src={`/cases/${c.slug}/cover.webp`}
                    alt={`Marca ${c.cliente}`}
                    loading="lazy"
                    decoding="async"
                  />
                </span>
                <span class="case-card__index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <span class="case-card__overlay">
                  <span class="case-card__cat">{c.setor}</span>
                  <span class="case-card__name">{c.cliente}</span>
                  <span class="case-card__cta">
                    Ver case
                    <span class="case-card__cta-arrow" aria-hidden="true">→</span>
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

  </section>

  <!-- ========================= DEPOIMENTOS ======================== -->
  <section id="depoimentos" class="section reviews" data-surface="light">
    <div class="container">
      <div class="section-head reviews__head">
        <p class="eyebrow reveal">Depoimentos</p>
        <h2 class="section-title reveal">
          O que muda quando a marca <span class="t-em">sai do lugar comum</span>.
        </h2>
      </div>

      <div class="reviews__stage reveal" data-reviews>
        <!-- fotos dos clientes: clicar troca o depoimento; o ativo ganha anel -->
        <div class="reviews__people" data-reviews-people>
          {reviews.map((r, i) => (
            <button
              class:list={['reviews__person', i === 0 && 'is-active']}
              type="button"
              data-review-avatar
              aria-label={`Ver depoimento de ${r.name}`}
            >
              <span class="reviews__person-img">
                {r.photo ? (
                  <img src={r.photo} alt="" loading="lazy" decoding="async" />
                ) : (
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 12.6a4.3 4.3 0 1 0 0-8.6 4.3 4.3 0 0 0 0 8.6Zm0 1.8c-3.6 0-8 1.9-8 5.2V21h16v-1.4c0-3.3-4.4-5.2-8-5.2Z" />
                  </svg>
                )}
              </span>
            </button>
          ))}
        </div>

        <svg class="reviews__quote-icon" viewBox="0 0 48 48" aria-hidden="true">
          <path d="M 13.5 10 A 8.5 8.5 0 0 0 13.5 27 A 8.5 8.5 0 0 0 18.291016 25.519531 C 17.422273 29.222843 15.877848 31.803343 14.357422 33.589844 C 12.068414 36.279429 9.9433594 37.107422 9.9433594 37.107422 A 1.50015 1.50015 0 1 0 11.056641 39.892578 C 11.056641 39.892578 13.931586 38.720571 16.642578 35.535156 C 19.35357 32.349741 22 27.072581 22 19 A 1.50015 1.50015 0 0 0 21.984375 18.78125 A 8.5 8.5 0 0 0 13.5 10 z M 34.5 10 A 8.5 8.5 0 0 0 34.5 27 A 8.5 8.5 0 0 0 39.291016 25.519531 C 38.422273 29.222843 36.877848 31.803343 35.357422 33.589844 C 33.068414 36.279429 30.943359 37.107422 30.943359 37.107422 A 1.50015 1.50015 0 1 0 32.056641 39.892578 C 32.056641 39.892578 34.931586 38.720571 37.642578 35.535156 C 40.35357 32.349741 43 27.072581 43 19 A 1.50015 1.50015 0 0 0 42.984375 18.78125 A 8.5 8.5 0 0 0 34.5 10 z" />
        </svg>

        <div class="reviews__viewport" data-reviews-viewport>
          {reviews.map((r, i) => (
            <figure class:list={['review', i === 0 && 'is-active']} data-review>
              <figcaption class="review__by">
                <span class="review__name">{r.name}</span>
                <span class="review__role">{r.role}</span>
              </figcaption>
              <blockquote class="review__quote">{r.quote}</blockquote>
            </figure>
          ))}
        </div>
      </div>

      <p class="reviews__flag reveal">
        Exemplos — substituir pelos depoimentos e fotos reais dos clientes.
      </p>
    </div>
  </section>

  <!-- ========================= CTA FINAL ========================== -->
  <section class="section cta-final">
    <FluxBand class="cta-final__flux" texture="otto-band" />
    <div class="cta-final__scrim" aria-hidden="true"></div>
    <div class="container cta-final__content">
      <h2 class="cta-final__headline reveal">
        <span class="cta-final__l1">Sua marca está sendo</span>
        <span class="cta-final__l2">escolhida</span>
        <span class="cta-final__l3">ou apenas comparada?</span>
      </h2>
      <p class="cta-final__sub reveal">
        O diagnóstico mostra onde ela perde valor e o que precisa mudar.
      </p>
      <a class="btn btn-primary cta-final__btn reveal" href={DIAGNOSTIC_URL} target="_blank" rel="noopener noreferrer">
        Começar pelo diagnóstico
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  // Carrossel de cases: setas rolam a trilha por um card. Sem biblioteca.
  const track = document.querySelector<HTMLElement>('[data-cases-track]');
  const prev = document.querySelector<HTMLButtonElement>('[data-cases-prev]');
  const next = document.querySelector<HTMLButtonElement>('[data-cases-next]');

  if (track && prev && next) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const stepSize = () => {
      const slide = track.querySelector<HTMLElement>('.case-slide');
      if (!slide) return 320;
      const gap = parseFloat(getComputedStyle(track).columnGap || '24') || 24;
      return slide.getBoundingClientRect().width + gap;
    };
    const go = (dir: number) =>
      track.scrollBy({ left: dir * stepSize(), behavior: reduce ? 'auto' : 'smooth' });

    prev.addEventListener('click', () => go(-1));
    next.addEventListener('click', () => go(1));

    // desabilita a seta quando não há para onde ir
    const sync = () => {
      const max = track.scrollWidth - track.clientWidth - 2;
      prev.disabled = track.scrollLeft <= 2;
      next.disabled = track.scrollLeft >= max;
    };
    track.addEventListener('scroll', sync, { passive: true });
    window.addEventListener('resize', sync);
    sync();
  }
</script>

<script>
  // Depoimentos: fila de fotos; clicar numa foto troca a fala (fade-through).
  // A foto ativa ganha o anel. Autoplay avança e pausa no hover/foco; sob
  // prefers-reduced-motion não há autoplay (só clique manual).
  const stage = document.querySelector<HTMLElement>('[data-reviews]');
  const viewport = stage?.querySelector<HTMLElement>('[data-reviews-viewport]');
  const slides = viewport ? Array.from(viewport.querySelectorAll<HTMLElement>('[data-review]')) : [];
  const avatars = stage
    ? Array.from(stage.querySelectorAll<HTMLButtonElement>('[data-review-avatar]'))
    : [];

  if (stage && slides.length > 1) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let index = 0;
    let timer: number | undefined;

    const show = (n: number) => {
      index = (n + slides.length) % slides.length;
      slides.forEach((s, i) => {
        s.classList.toggle('is-active', i === index);
        s.setAttribute('aria-hidden', i === index ? 'false' : 'true');
      });
      avatars.forEach((a, i) => {
        a.classList.toggle('is-active', i === index);
        a.setAttribute('aria-pressed', i === index ? 'true' : 'false');
      });
    };

    const restart = () => {
      if (reduce) return;
      window.clearInterval(timer);
      timer = window.setInterval(() => show(index + 1), 6000);
    };

    // estado inicial de acessibilidade
    slides.forEach((s, i) => s.setAttribute('aria-hidden', i === 0 ? 'false' : 'true'));
    avatars.forEach((a, i) => {
      a.setAttribute('aria-pressed', i === 0 ? 'true' : 'false');
      a.addEventListener('click', () => { show(i); restart(); });
    });

    // pausa autoplay quando o cursor/foco está na área
    stage.addEventListener('mouseenter', () => window.clearInterval(timer));
    stage.addEventListener('mouseleave', restart);
    stage.addEventListener('focusin', () => window.clearInterval(timer));
    stage.addEventListener('focusout', restart);

    restart();
  }
</script>

<style>
  /* ============================ HERO ============================ */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: min(88vh, 820px);
    padding-block: var(--space-8);
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    overflow: hidden;
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    /* vídeo já está a ~20% sobre o preto da marca, então o scrim é leve:
       só um respiro no topo (sob o header) e a fusão com a seção seguinte */
    background: linear-gradient(
      to bottom,
      rgb(var(--otto-ink-rgb) / 0.35),
      transparent 18%,
      transparent 72%,
      rgb(var(--otto-ink-rgb) / 0.85)
    );
  }

  .hero__container {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .hero__content {
    max-width: 46rem;
    margin-inline: auto;
    text-align: center;
  }

  .hero__headline {
    margin-top: var(--space-4);
    font-size: clamp(2.25rem, 4.2vw + 0.9rem, 3.5rem);
    letter-spacing: var(--tracking-tight);
    line-height: 1.06;
    text-wrap: balance;
  }

  /* diagramação: o "problema" em peso leve e tom apagado; a "resposta" em
     Pogonia Black, com a palavra-chave em vermelho. Contraste de peso e cor. */
  .hero__headline-quiet {
    display: block;
    font-weight: 400;
    color: rgb(var(--otto-offwhite-rgb) / 0.72);
  }

  .hero__headline-accent {
    display: block;
    margin-top: 0.12em;
    font-weight: 900;
    color: var(--otto-offwhite);
    letter-spacing: var(--tracking-tighter);
  }

  .hero__headline-accent em {
    font-style: normal;
    color: var(--otto-red);
  }

  .hero__descritor {
    margin: var(--space-5) auto 0;
    max-width: 36rem;
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: rgb(var(--otto-offwhite-rgb) / 0.8);
  }

  .hero__signature {
    margin-top: var(--space-5);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-tight);
  }

  .hero__signature em {
    font-style: normal;
    font-weight: 900;
    color: var(--otto-red);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    margin-top: var(--space-6);
  }

  .hero__whats {
    color: var(--otto-offwhite);
  }

  /* ===================== CABEÇALHOS DE SEÇÃO ==================== */
  .section-head {
    max-width: 40rem;
    margin-bottom: var(--space-8);
  }

  .section-title {
    margin-top: var(--space-4);
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-snug);
    text-wrap: balance;
  }

  .section-lead {
    margin-top: var(--space-5);
    max-width: 38rem;
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  /* ========================== SOLUÇÕES ========================= */
  /* duas colunas para encurtar a lista; cada item empilha nome + descrição.
     O grid deixa as duas células de uma linha com a mesma altura, então as
     bordas inferiores alinham. */
  .solucoes__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .solucao {
    padding-block: var(--space-5);
    border-bottom: 1px solid var(--color-border);
    transition: background-color var(--duration-base) var(--ease-out);
  }

  .solucao__head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .solucao__arrow {
    color: var(--otto-red);
    font-size: var(--text-md);
    transition: transform var(--duration-base) var(--ease-out);
  }

  .solucao__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-snug);
  }

  .solucao__desc {
    margin-top: var(--space-3);
    padding-left: calc(var(--text-md) + var(--space-3));
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    max-width: 44ch;
  }

  .solucao:hover .solucao__arrow {
    transform: translateX(6px);
  }

  .solucoes__cta {
    margin-top: var(--space-7);
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: baseline;
  }

  /* =========================== MÉTODO ========================== */
  .metodo {
    background-color: var(--otto-charcoal);
    color: var(--otto-offwhite);
  }

  .patamares {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }

  .patamar {
    display: flex;
    gap: var(--space-5);
    padding: var(--space-6);
    margin-left: calc(var(--step) * clamp(0rem, 4vw, 3rem));
