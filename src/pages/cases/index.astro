---
/*
  Índice de cases. Antes isso era só uma âncora na home, o que deixava os três
  cases sem uma URL-mãe para acumular autoridade e sem caminho de volta: quem
  entrava por um case não achava os outros.
*/
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cases } from '../../data/cases';
import { DIAGNOSTIC_URL } from '../../config';
import { breadcrumb, canonicalUrl } from '../../data/schema';
import { imgSize } from '../../data/image-dimensions';

const schema = [
  {
    '@type': 'CollectionPage',
    name: 'Cases de branding e identidade visual',
    url: canonicalUrl('/cases'),
    hasPart: cases.map((c) => ({
      '@type': 'Article',
      headline: c.seoTitle,
      url: canonicalUrl(`/cases/${c.slug}`),
    })),
  },
  breadcrumb([{ name: 'Cases', path: '/cases' }]),
];
---

<BaseLayout
  title="Cases de branding e identidade visual | Otto Branding"
  description="Cases de branding, posicionamento e identidade visual da Otto Branding. Escola de beleza, barbearia e turismo. Estratégia antes de estética."
  schema={schema}
>
  <section class="ihero">
    <div class="ihero__glow" aria-hidden="true"></div>
    <div class="container ihero__inner">
      <p class="eyebrow rise" style="--rise-delay: 60ms">Cases</p>
      <h1 class="ihero__title rise" style="--rise-delay: 140ms">
        Marcas de <span class="t-em">Otto Patamar</span>
      </h1>
      <p class="ihero__lead rise" style="--rise-delay: 240ms">
        Três negócios que já eram bons no que faziam e estavam sendo comparados
        por preço. Em cada um, a estratégia veio antes da estética.
      </p>
    </div>
  </section>

  <section class="section ilist" data-surface="light">
    <div class="container">
      <ol class="ilist__grid reveal-group">
        {cases.map((c, i) => (
          <li class="reveal" style={`--reveal-index: ${i}`}>
            <article class="icase">
              <a class="icase__media" href={`/cases/${c.slug}/`} tabindex="-1" aria-hidden="true">
                <img
                  src={`/cases/${c.slug}/cover.webp`}
                  alt=""
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                  {...imgSize(`/cases/${c.slug}/cover.webp`)}
                />
              </a>
              <div class="icase__body">
                <p class="icase__meta">{c.setor} · {c.ano}</p>
                <h2 class="icase__name">
                  <a href={`/cases/${c.slug}/`}>{c.cliente}</a>
                </h2>
                <p class="icase__tensao">{c.tensao}</p>
                <p class="icase__frase">{c.frase}</p>
                <p class="icase__go">
                  <span class="link-arrow">
                    <span class="link-arrow__icon" aria-hidden="true">→</span>
                    <span class="link-arrow__label">Ver o case completo</span>
                  </span>
                </p>
              </div>
            </article>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section icta">
    <div class="container icta__content">
      <h2 class="icta__headline reveal">Sua marca está no patamar do seu trabalho?</h2>
      <a class="btn btn-primary reveal" href={DIAGNOSTIC_URL} target="_blank" rel="noopener noreferrer">
        Começar pelo diagnóstico
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .ihero {
    position: relative;
    overflow: hidden;
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    padding-block: var(--space-9);
  }

  .ihero__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(58% 68% at 85% 0%, rgb(var(--otto-red-rgb) / 0.15), transparent 62%);
  }

  .ihero__inner {
    position: relative;
    max-width: 42rem;
  }

  .ihero__title {
    margin-top: var(--space-4);
    font-size: clamp(2.1rem, 3.4vw + 1rem, 3.4rem);
    letter-spacing: var(--tracking-tighter);
    line-height: 1.05;
  }

  .ihero__lead {
    margin-top: var(--space-5);
    max-width: 36rem;
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: rgb(var(--otto-offwhite-rgb) / 0.8);
  }

  /* Lista, não grade de cards: com três cases, a linha larga deixa a tensão
     de cada projeto legível — que é o que faz clicar. */
  .ilist__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .icase {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
    align-items: center;
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .ilist__grid > li:last-child .icase {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .icase__media {
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-md);
    background-color: rgb(36 36 36 / 0.06);
  }

  .icase__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .icase:hover .icase__media img {
    transform: scale(1.03);
  }

  .icase__meta {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .icase__name {
    margin-top: var(--space-3);
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-snug);
  }

  .icase__name a {
    color: inherit;
    text-decoration: none;
  }

  .icase__name a:hover {
    color: var(--otto-red-text-on-light);
  }

  .icase__tensao {
    margin-top: var(--space-3);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    max-width: 34ch;
  }

  .icase__frase {
    margin-top: var(--space-5);
    padding-left: var(--space-4);
    border-left: 2px solid var(--otto-red);
    font-family: var(--font-display);
    font-size: var(--text-md);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    max-width: 32ch;
  }

  .icase__go {
    margin-top: var(--space-5);
    font-size: var(--text-sm);
  }

  /* alterna o lado da imagem, para a lista não virar um carimbo repetido */
  .ilist__grid > li:nth-child(even) .icase__media {
    order: 2;
  }

  .icta {
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    text-align: center;
  }

  .icta__content {
    max-width: 34rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .icta__headline {
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-tighter);
    line-height: var(--leading-tight);
    text-wrap: balance;
  }

  @media (max-width: 52rem) {
    .icase {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .ilist__grid > li:nth-child(even) .icase__media {
      order: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .icase__media img {
      transition: none;
    }
    .icase:hover .icase__media img {
      transform: none;
    }
  }
</style>
