---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cases, type CaseStudy } from '../../data/cases';
import { servicos } from '../../data/servicos';
import { SITE_URL, WHATSAPP_URL, DIAGNOSTIC_URL } from '../../config';
import { ORG_ID, PERSON_ID, breadcrumb } from '../../data/schema';

export function getStaticPaths() {
  return cases.map((c) => ({ params: { slug: c.slug }, props: { c } }));
}

interface Props {
  c: CaseStudy;
}
const { c } = Astro.props;
const base = `/cases/${c.slug}`;
const [lead, ...rest] = c.texto;

// Link de saída para o serviço que este case prova — sem isso, todo case é um
// beco sem saída: o leitor termina convencido e não tem para onde ir.
const servico = servicos.find((s) => `/${s.slug}` === c.servico);

const schema = [
  {
    '@type': 'Article',
    headline: c.seoTitle,
    description: c.metaDescription,
    image: `${SITE_URL}${base}/cover.webp`,
    datePublished: c.datePublished,
    author: { '@id': PERSON_ID },
    publisher: { '@id': ORG_ID },
    mainEntityOfPage: `${SITE_URL}${base}`,
    about: [
      { '@type': 'Thing', name: 'Identidade visual' },
      { '@type': 'Thing', name: c.setor },
    ],
  },
  breadcrumb([
    { name: 'Cases', path: '/cases' },
    { name: c.cliente, path: base },
  ]),
];
---

<BaseLayout
  title={c.seoTitle}
  description={c.metaDescription}
  ogImage={`/og/${c.slug}.jpg`}
  ogType="article"
  schema={schema}
>
  <!-- ===================== HERO ===================== -->
  <section class="chero">
    <div class="chero__glow" aria-hidden="true"></div>
    <div class="container chero__inner">
      <a class="chero__back link-arrow rise" href="/cases" style="--rise-delay: 40ms">
        <span class="link-arrow__icon" aria-hidden="true">←</span>
        <span class="link-arrow__label">Cases</span>
      </a>

      <div class="chero__body">
        <p class="eyebrow rise" style="--rise-delay: 120ms">{c.setor} · {c.ano}</p>
        <h1 class="chero__title rise" style="--rise-delay: 200ms">{c.h1}</h1>
        <p class="chero__lead rise" style="--rise-delay: 300ms">{c.tensao}</p>
      </div>
    </div>
  </section>

  <!-- ===================== CAPA (full-bleed) ===================== -->
  <figure class="ccover">
    <img
      class="ccover__img"
      src={`${base}/cover.webp`}
      alt={`Identidade visual da ${c.cliente}, ${c.setor.toLowerCase()}`}
      fetchpriority="high"
    />
  </figure>

  <!-- ===================== ENTREGAS ===================== -->
  <section class="section cwrap" data-surface="light">
    <div class="container cintro">
      <div class="cintro__col">
        <p class="eyebrow reveal">O trabalho</p>
        <p class="cintro__lead reveal">{lead}</p>
      </div>
      <aside class="cintro__aside reveal">
        <h2 class="cintro__aside-title">Entregas</h2>
        <ul class="centregas">
          {c.entregas.map((e) => <li>{e}</li>)}
        </ul>
        {servico && (
          <a class="cintro__servico link-arrow" href={c.servico}>
            <span class="link-arrow__icon" aria-hidden="true">→</span>
            <span class="link-arrow__label">Sobre {servico.nome.toLowerCase()}</span>
          </a>
        )}
      </aside>
    </div>

    {rest.length > 0 && (
      <div class="container cbody">
        {rest.map((p) => (
          <p class="cbody__p reveal">{p}</p>
        ))}
      </div>
    )}
  </section>

  <!-- ===================== A VIRADA (pull-quote) ===================== -->
  <section class="cquote">
    <div class="container cquote__inner">
      <span class="cquote__mark" aria-hidden="true">“</span>
      <blockquote class="cquote__text reveal">{c.frase}</blockquote>
    </div>
  </section>

  <!-- ===================== GALERIA ===================== -->
  <section class="cgallery-sec">
    <p class="container cgallery__label reveal">A marca, ponto a ponto</p>
    <div class="container cgallery">
      {c.imagens.map((img, i) => (
        <figure class:list={['cfig', 'reveal', img.col === 'half' && 'cfig--half']}>
          <img
            src={`${base}/${img.n}.webp`}
            alt={img.alt}
            loading={i < 2 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </figure>
      ))}
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="section ccta">
    <div class="container ccta__content">
      <h2 class="ccta__headline reveal">Sua marca está no patamar do seu trabalho?</h2>
      <a class="btn btn-primary reveal" href={DIAGNOSTIC_URL} target="_blank" rel="noopener noreferrer">
        Começar pelo diagnóstico
      </a>
      <div class="ccta__secondary reveal">
        <a class="ccta__link link-arrow" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">
          <span class="link-arrow__icon" aria-hidden="true">→</span>
          <span class="link-arrow__label">Falar no WhatsApp</span>
        </a>
        <a class="ccta__link link-arrow" href="/cases">
          <span class="link-arrow__icon" aria-hidden="true">→</span>
          <span class="link-arrow__label">Ver outros cases</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===================== HERO ===================== */
  .chero {
    position: relative;
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    overflow: hidden;
    padding-block: var(--space-8) var(--space-9);
  }

  .chero__glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(60% 70% at 82% 0%, rgb(var(--otto-red-rgb) / 0.16), transparent 60%);
  }

  .chero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .chero__back {
    width: fit-content;
    color: rgb(var(--otto-offwhite-rgb) / 0.85);
    font-size: var(--text-sm);
  }

  .chero__title {
    margin-top: var(--space-3);
    font-size: clamp(2.1rem, 3.2vw + 1rem, 3.4rem);
    letter-spacing: var(--tracking-tight);
    line-height: 1.05;
    text-wrap: balance;
  }

  .chero__lead {
    margin-top: var(--space-4);
    max-width: 40rem;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: rgb(var(--otto-offwhite-rgb) / 0.9);
  }

  /* ===================== CAPA ===================== */
  .ccover {
    margin: 0;
    background-color: var(--otto-ink);
    line-height: 0;
  }

  .ccover img {
    width: 100%;
    height: auto;
    max-height: 82vh;
    object-fit: cover;
    display: block;
  }

  /* ===================== INTRO + ENTREGAS ===================== */
  .cintro {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .cintro__lead {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    text-wrap: pretty;
  }

  .cintro__aside {
    padding-top: var(--space-2);
    border-top: 2px solid var(--otto-red);
  }

  .cintro__aside-title {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .centregas {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .centregas li {
    padding-left: var(--space-4);
    position: relative;
  }

  .centregas li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--otto-red);
  }

  .cintro__servico {
    display: inline-flex;
    margin-top: var(--space-5);
    font-size: var(--text-sm);
    color: var(--otto-red-text-on-light);
  }

  .cbody {
    margin-top: var(--space-8);
    max-width: 42rem;
  }

  .cbody__p {
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  .cbody__p + .cbody__p {
    margin-top: var(--space-5);
  }

  /* ===================== A VIRADA (pull-quote) ===================== */
  .cquote {
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    padding-block: var(--space-section);
  }

  .cquote__inner {
    position: relative;
    max-width: 48rem;
  }

  .cquote__mark {
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3rem, 6vw, 4.5rem);
    line-height: 0.6;
    color: var(--otto-red);
  }

  .cquote__text {
    margin: var(--space-4) 0 0;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: 1.18;
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
  }

  /* ===================== GALERIA ===================== */
  /* fundo escuro: a galeria vira "exposição", as peças da marca saltam.
     Fecha o bloco escuro com o pull-quote e o CTA. */
  .cgallery-sec {
    background-color: var(--otto-charcoal);
    color: var(--otto-offwhite);
    padding-block: var(--space-section);
  }

  .cgallery__label {
    margin: 0 auto var(--space-6);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: rgb(var(--otto-offwhite-rgb) / 0.55);
  }

  /* grade de 2 colunas: peças em par (half) e telas cheias (full) dão ritmo */
  .cgallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }

  .cfig {
    grid-column: span 2;
    margin: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    background-color: rgb(var(--otto-offwhite-rgb) / 0.03);
    border: 1px solid rgb(var(--otto-offwhite-rgb) / 0.1);
  }

  .cfig--half {
    grid-column: span 1;
  }

  .cfig img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  @media (prefers-reduced-motion: no-preference) {
    .cfig:hover img {
      transform: scale(1.02);
    }
  }

  @media (max-width: 40rem) {
    .cgallery {
      gap: var(--space-4);
    }
    .cfig--half {
      grid-column: span 2;
    }
  }

  /* ===================== CTA ===================== */
  .ccta {
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    text-align: center;
  }

  .ccta__content {
    max-width: 36rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }

  .ccta__headline {
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-tighter);
    line-height: var(--leading-tight);
    text-wrap: balance;
  }

  .ccta__secondary {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4) var(--space-6);
  }

  .ccta__link {
    color: rgb(var(--otto-offwhite-rgb) / 0.72);
    font-size: var(--text-sm);
  }

  .ccta__link:hover {
    color: var(--otto-offwhite);
  }

  /* ===================== RESPONSIVO ===================== */
  @media (max-width: 60rem) {
    .cintro {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }

  @media (max-width: 40rem) {
    .chero {
      min-height: 76vh;
    }
    .cgallery {
      gap: var(--space-4);
    }
  }
</style>
