---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cases, type CaseStudy } from '../../data/cases';
import { WHATSAPP_URL } from '../../config';

export function getStaticPaths() {
  return cases.map((c) => ({ params: { slug: c.slug }, props: { c } }));
}

interface Props {
  c: CaseStudy;
}
const { c } = Astro.props;
const base = `/cases/${c.slug}`;
const [lead, ...rest] = c.texto;
---

<BaseLayout
  title={`${c.cliente} — Case Otto Branding`}
  description={c.tensao}
>
  <!-- ===================== HERO ===================== -->
  <section class="chero">
    <div class="chero__glow" aria-hidden="true"></div>
    <div class="container chero__inner">
      <a class="chero__back link-arrow rise" href="/#cases" style="--rise-delay: 40ms">
        <span class="link-arrow__icon" aria-hidden="true">←</span>
        <span class="link-arrow__label">Cases</span>
      </a>

      <div class="chero__body">
        <p class="eyebrow rise" style="--rise-delay: 120ms">{c.setor} · {c.ano}</p>
        <h1 class="chero__title rise" style="--rise-delay: 200ms">{c.cliente}</h1>
        <p class="chero__lead rise" style="--rise-delay: 300ms">{c.tensao}</p>
      </div>
    </div>
  </section>

  <!-- ===================== CAPA (full-bleed) ===================== -->
  <figure class="ccover">
    <picture>
      <source srcset={`${base}/cover.avif`} type="image/avif" />
      <source srcset={`${base}/cover.webp`} type="image/webp" />
      <img src={`${base}/cover.webp`} alt={`Marca ${c.cliente}`} fetchpriority="high" />
    </picture>
  </figure>

  <!-- ===================== ENTREGAS ===================== -->
  <section class="section cwrap" data-surface="light">
    <div class="container cintro">
      <div class="cintro__col">
        <p class="eyebrow reveal">O trabalho</p>
        <p class="cintro__lead reveal">{lead}</p>
      </div>
      <aside class="cintro__aside reveal">
        <h2 class="cintro__aside-title">Entregas</h2>
        <ul class="centregas">
          {c.entregas.map((e) => <li>{e}</li>)}
        </ul>
      </aside>
    </div>

    {rest.length > 0 && (
      <div class="container cbody">
        {rest.map((p) => (
          <p class="cbody__p reveal">{p}</p>
        ))}
      </div>
    )}
  </section>

  <!-- ===================== GALERIA ===================== -->
  <section class="cgallery-sec" data-surface="light">
    <div class="container cgallery">
      {c.imagens.map((img, i) => (
        <figure class="cfig reveal">
          <img
            src={`${base}/${img.n}.webp`}
            alt={`${img.alt} — ${c.cliente}`}
            loading={i < 2 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </figure>
      ))}
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="section ccta">
    <div class="container ccta__content">
      <h2 class="ccta__headline reveal">Sua marca está no patamar do seu trabalho?</h2>
      <a class="btn btn-primary reveal" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">
        Começar uma conversa
      </a>
      <a class="ccta__more link-arrow reveal" href="/#cases">
        <span class="link-arrow__icon" aria-hidden="true">→</span>
        <span class="link-arrow__label">Ver outros cases</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===================== HERO ===================== */
  .chero {
    position: relative;
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    overflow: hidden;
    padding-block: var(--space-8) var(--space-9);
  }

  .chero__glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(60% 70% at 82% 0%, rgb(var(--otto-red-rgb) / 0.16), transparent 60%);
  }

  .chero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .chero__back {
    width: fit-content;
    color: rgb(var(--otto-offwhite-rgb) / 0.85);
    font-size: var(--text-sm);
  }

  .chero__title {
    margin-top: var(--space-3);
    font-size: clamp(2.5rem, 6vw + 1rem, 5rem);
    letter-spacing: var(--tracking-tighter);
    line-height: 1.02;
    text-wrap: balance;
  }

  .chero__lead {
    margin-top: var(--space-4);
    max-width: 40rem;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: rgb(var(--otto-offwhite-rgb) / 0.9);
  }

  /* ===================== CAPA ===================== */
  .ccover {
    margin: 0;
    background-color: var(--otto-ink);
    line-height: 0;
  }

  .ccover img {
    width: 100%;
    height: auto;
    max-height: 82vh;
    object-fit: cover;
    display: block;
  }

  /* ===================== INTRO + ENTREGAS ===================== */
  .cintro {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .cintro__lead {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    text-wrap: pretty;
  }

  .cintro__aside {
    padding-top: var(--space-2);
    border-top: 2px solid var(--otto-red);
  }

  .cintro__aside-title {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .centregas {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .centregas li {
    padding-left: var(--space-4);
    position: relative;
  }

  .centregas li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--otto-red);
  }

  .cbody {
    margin-top: var(--space-8);
    max-width: 42rem;
  }

  .cbody__p {
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  .cbody__p + .cbody__p {
    margin-top: var(--space-5);
  }

  /* ===================== GALERIA ===================== */
  .cgallery-sec {
    padding-bottom: var(--space-section);
  }

  .cgallery {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .cfig {
    margin: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    background-color: rgb(var(--otto-charcoal-rgb) / 0.04);
    border: 1px solid var(--color-border);
  }

  .cfig img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ===================== CTA ===================== */
  .ccta {
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    text-align: center;
  }

  .ccta__content {
    max-width: 36rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }

  .ccta__headline {
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-tighter);
    line-height: var(--leading-tight);
    text-wrap: balance;
  }

  .ccta__more {
    color: rgb(var(--otto-offwhite-rgb) / 0.8);
    font-size: var(--text-sm);
  }

  /* ===================== RESPONSIVO ===================== */
  @media (max-width: 60rem) {
    .cintro {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }

  @media (max-width: 40rem) {
    .chero {
      min-height: 76vh;
    }
    .cgallery {
      gap: var(--space-4);
    }
  }
</style>
