---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignatureFlux from '../components/SignatureFlux.astro';
import { DIAGNOSTIC_URL } from '../config';

/*
  Página MODELO de case. Layout completo e definitivo; o CONTEÚDO é molde.
  Estrutura na linha da referência (Farda): capítulos curtos de texto
  intercalados com imagens grandes em tela. Cada capítulo traz:
   - rótulo do que é a seção,
   - nota [O que entra aqui] do que escrever,
   - texto de EXEMPLO marcado,
   - placeholder de imagem grande para o material real.
*/

const meta = [
  { k: 'Cliente', v: '[Nome do cliente]' },
  { k: 'Setor', v: '[Segmento]' },
  { k: 'Entregas', v: '[Posicionamento, identidade…]' },
  { k: 'Ano', v: '[2026]' },
];

const chapters = [
  {
    n: '01',
    title: 'O problema',
    note: '[O que entra aqui: a tensão real do cliente. O que travava a marca — comparada por preço, confundida com concorrentes, sem espaço próprio. Concreto, não genérico.]',
    eg: 'A marca disputava atenção num setor saturado onde todos prometiam a mesma coisa. Sem um território próprio, a decisão de compra caía sempre para o menor preço.',
    figure: '[Imagem grande: o cenário / o "antes" da marca]',
    surface: 'light',
  },
  {
    n: '02',
    title: 'O que estava em jogo',
    note: '[O que entra aqui: o risco de negócio. Margem corroída, dependência de desconto, crescimento travado. Traduza o problema de marca em consequência financeira.]',
    eg: 'Cada negociação começava pelo desconto. A marca crescia em volume, mas a margem encolhia — e o dono trabalhava mais para faturar o mesmo.',
    figure: '[Imagem grande: dado de negócio / contexto de mercado]',
    surface: 'light',
  },
  {
    n: '03',
    title: 'A decisão',
    note: '[O que entra aqui: a decisão estratégica e o porquê. Qual espaço a marca passou a ocupar, o que deixou de tentar ser, e a lógica por trás. É o coração do case.]',
    eg: 'Em vez de competir como “mais um”, reposicionamos a marca em torno de um único território defensável e reconstruímos a identidade para sustentá-lo em cada ponto de contato.',
    figure: '[Imagem grande: a nova marca / o território visual]',
    surface: 'dark',
  },
];
---

<BaseLayout
  title="Case modelo — Otto Branding"
  description="Página modelo de case: molde de layout e roteiro de escrita."
>
  <!-- ===================== HERO DO CASE ===================== -->
  <section class="case-hero">
    <SignatureFlux class="case-hero__flux" texture="otto-flux" />
    <div class="case-hero__scrim" aria-hidden="true"></div>
    <div class="container case-hero__content">
      <a class="case-hero__back link-arrow" href="/#cases">
        <span class="link-arrow__icon" aria-hidden="true">←</span>
        <span class="link-arrow__label">Voltar aos cases</span>
      </a>
      <p class="eyebrow rise" style="--rise-delay: 60ms">Case modelo · Exemplo de layout</p>
      <h1 class="case-hero__title rise" style="--rise-delay: 140ms">
        [Nome do cliente] <span>saiu do lugar comum e passou a ser escolhido.</span>
      </h1>
      <p class="case-hero__lead rise" style="--rise-delay: 240ms">
        [Uma linha: quem é o cliente e o salto de percepção que a marca entregou.
        Escreva depois que o resultado existir.]
      </p>
      <dl class="case-hero__meta rise" style="--rise-delay: 320ms">
        {meta.map((m) => (
          <div>
            <dt>{m.k}</dt>
            <dd>{m.v}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ===================== CAPA (imagem grande, full-bleed) ===================== -->
  <div class="case-cover reveal" aria-hidden="true">
    <span>[Imagem de capa — key visual da marca em tela cheia]</span>
  </div>

  <!-- ===================== CAPÍTULOS ===================== -->
  {chapters.map((c) => (
    <section class:list={['section', 'case-chapter', c.surface === 'dark' && 'case-chapter--dark']} data-surface={c.surface === 'light' ? 'light' : undefined}>
      <div class="container">
        <div class="case-chapter__intro">
          <span class="case-num reveal">{c.n}</span>
          <h2 class="case-chapter__title reveal">{c.title}</h2>
          <p class="tpl-note reveal">{c.note}</p>
          <p class="tpl-eg reveal">
            <span class="tpl-eg__flag">Exemplo</span>
            {c.eg}
          </p>
        </div>
      </div>
      <div class="container">
        <figure class="case-figure reveal" aria-hidden="true">
          <span>{c.figure}</span>
        </figure>
      </div>
    </section>
  ))}

  <!-- ==================== O RESULTADO ==================== -->
  <section class="section case-result" data-surface="light">
    <div class="container">
      <div class="case-chapter__intro reveal">
        <span class="case-num">04</span>
        <h2 class="case-chapter__title">O resultado</h2>
        <p class="tpl-note">
          [O que entra aqui: o resultado com NÚMERO. Sem número, esta seção não
          existe — é ela que transforma vitrine em prova. Peça o dado ao cliente.]
        </p>
      </div>

      <div class="case-stats reveal-group">
        {[
          { n: '+38%', l: '[métrica de exemplo — ex.: ticket médio]' },
          { n: '2,4×', l: '[métrica de exemplo — ex.: propostas fechadas]' },
          { n: '−0', l: '[métrica de exemplo — ex.: pedidos de desconto]' },
        ].map((s, i) => (
          <div class="case-stat reveal" style={`--reveal-index: ${i}`}>
            <span class="case-stat__n">{s.n}</span>
            <span class="case-stat__l">{s.l}</span>
          </div>
        ))}
      </div>
      <p class="case-result__flag">Números de exemplo — substituir pelos reais do cliente.</p>
    </div>

    <div class="container">
      <figure class="case-figure reveal" aria-hidden="true">
        <span>[Imagem grande: aplicação-herói / prova visual do resultado]</span>
      </figure>
    </div>
  </section>

  <!-- ================ APLICAÇÕES / GALERIA ================ -->
  <section class="section case-gallery-sec" data-surface="light">
    <div class="container">
      <div class="case-chapter__intro reveal">
        <span class="case-num">05</span>
        <h2 class="case-chapter__title">Aplicações</h2>
        <p class="tpl-note">
          [O que entra aqui: imagens do sistema aplicado — logo, papelaria,
          embalagem, digital, ambiente. Mostrar consistência, não só o logo.]
        </p>
      </div>
      <div class="case-gallery reveal-group">
        {[
          '[Imagem grande]',
          '[Imagem grande]',
          '[Imagem — vertical]',
          '[Imagem — vertical]',
        ].map((label, i) => (
          <figure class={`case-gallery__item ${i < 2 ? 'case-gallery__item--wide' : ''} reveal`} style={`--reveal-index: ${i}`} aria-hidden="true">
            <span>{label}</span>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="section case-cta">
    <div class="container case-cta__content">
      <h2 class="case-cta__headline reveal">Quer um resultado assim para a sua marca?</h2>
      <a class="btn btn-primary reveal" href={DIAGNOSTIC_URL}>Começar pelo diagnóstico</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===================== HERO DO CASE ===================== */
  .case-hero {
    position: relative;
    overflow: hidden;
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    padding-block: var(--space-9) var(--space-8);
    min-height: 68vh;
    display: flex;
    align-items: flex-end;
  }

  .case-hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgb(var(--otto-ink-rgb) / 0.95) 10%,
      rgb(var(--otto-ink-rgb) / 0.55) 55%,
      rgb(var(--otto-ink-rgb) / 0.2) 100%
    );
  }

  .case-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .case-hero__back {
    display: flex;
    width: fit-content;
    color: rgb(var(--otto-offwhite-rgb) / 0.8);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }

  .case-hero__title {
    margin-top: var(--space-4);
    max-width: 20ch;
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-tighter);
    line-height: var(--leading-tight);
  }

  .case-hero__title span {
    color: rgb(var(--otto-offwhite-rgb) / 0.6);
  }

  .case-hero__lead {
    margin-top: var(--space-5);
    max-width: 42rem;
    font-size: var(--text-md);
    color: rgb(var(--otto-offwhite-rgb) / 0.75);
  }

  .case-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    margin: var(--space-7) 0 0;
  }

  .case-hero__meta dt {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: rgb(var(--otto-offwhite-rgb) / 0.55);
  }

  .case-hero__meta dd {
    margin: var(--space-1) 0 0;
    font-weight: 500;
  }

  /* ===================== CAPA FULL-BLEED ===================== */
  .case-cover {
    width: 100%;
    aspect-ratio: 21 / 9;
    display: grid;
    place-items: center;
    color: rgb(var(--otto-offwhite-rgb) / 0.5);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    background:
      radial-gradient(80% 120% at 60% 10%, rgb(var(--otto-red-rgb) / 0.12), transparent 55%),
      linear-gradient(160deg, #2c2c2c, var(--otto-ink));
    border-bottom: 1px solid rgb(var(--otto-offwhite-rgb) / 0.08);
  }

  /* ===================== CAPÍTULOS ===================== */
  .case-chapter--dark {
    background-color: var(--otto-charcoal);
    color: var(--otto-offwhite);
  }

  .case-chapter__intro {
    max-width: 46rem;
  }

  .case-num {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--text-md);
    color: var(--otto-red);
    margin-bottom: var(--space-3);
  }

  .case-chapter__title {
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-snug);
  }

  .tpl-note {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    border-left: 2px dashed color-mix(in srgb, var(--color-text-secondary) 60%, transparent);
    padding-left: var(--space-4);
  }

  .tpl-eg {
    margin-top: var(--space-5);
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
  }

  .tpl-eg__flag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--otto-red);
    margin-right: var(--space-3);
    vertical-align: 0.15em;
  }

  /* Imagem grande de capítulo */
  .case-figure {
    margin: var(--space-8) 0 0;
    width: 100%;
    aspect-ratio: 16 / 9;
    display: grid;
    place-items: center;
    border-radius: var(--radius-md);
    border: 1px dashed color-mix(in srgb, currentColor 30%, transparent);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    background:
      radial-gradient(90% 120% at 65% 12%, rgb(var(--otto-red-rgb) / 0.08), transparent 55%),
      linear-gradient(160deg, rgb(128 128 128 / 0.08), rgb(128 128 128 / 0.02));
  }

  /* ===================== RESULTADO ===================== */
  .case-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-6);
  }

  .case-stat {
    padding-top: var(--space-5);
    border-top: 2px solid var(--otto-red);
  }

  .case-stat__n {
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--text-3xl);
    line-height: 1;
    letter-spacing: var(--tracking-tighter);
  }

  .case-stat__l {
    display: block;
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .case-result__flag {
    margin-top: var(--space-6);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--otto-red);
  }

  /* ===================== GALERIA ===================== */
  .case-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
    margin-top: var(--space-8);
  }

  .case-gallery__item {
    margin: 0;
    aspect-ratio: 3 / 4;
    display: grid;
    place-items: center;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    background: linear-gradient(160deg, rgb(36 36 36 / 0.04), transparent);
  }

  .case-gallery__item--wide {
    aspect-ratio: 16 / 10;
    grid-column: span 2;
  }

  /* ===================== CTA ===================== */
  .case-cta {
    background-color: var(--otto-ink);
    color: var(--otto-offwhite);
    text-align: center;
  }

  .case-cta__content {
    max-width: 34rem;
    margin-inline: auto;
  }

  .case-cta__headline {
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-6);
    text-wrap: balance;
  }

  /* ===================== RESPONSIVO ===================== */
  @media (max-width: 52rem) {
    .case-cover {
      aspect-ratio: 3 / 2;
    }
    .case-stats {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .case-gallery {
      grid-template-columns: 1fr;
    }
    .case-gallery__item,
    .case-gallery__item--wide {
      grid-column: auto;
      aspect-ratio: 4 / 3;
    }
  }
</style>
