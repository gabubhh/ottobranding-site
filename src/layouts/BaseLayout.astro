---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Preloader from '../components/Preloader.astro';
import FloatingActions from '../components/FloatingActions.astro';
import { organizationSchema, personSchema } from '../data/schema';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** caminho absoluto da imagem de compartilhamento (ex.: '/og/home.jpg') */
  ogImage?: string;
  ogType?: 'website' | 'article';
  /** blocos JSON-LD da página; organização e Gabriel já entram sempre */
  schema?: Record<string, unknown>[];
}

const {
  title,
  description = 'Estúdio de branding e identidade visual. Estratégia e posicionamento para marcas que precisam ser escolhidas, não comparadas por preço. Atendimento em todo o Brasil.',
  ogImage = '/og/default.jpg',
  ogType = 'website',
  schema = [],
} = Astro.props;

// Canônica com barra final, para bater exatamente com o que o @astrojs/sitemap
// gera (formato de diretório). URL canônica e sitemap divergentes confundem o
// buscador sobre qual é a página "de verdade".
const path = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonical = new URL(path, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

// Um único <script type="application/ld+json"> com @graph: as páginas
// referenciam a organização e o Gabriel por @id sem redeclarar os dados.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [organizationSchema, personSchema, ...schema],
};
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#242424" />

    <!-- Google Analytics (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-P21CXNHN1J"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-P21CXNHN1J');
    </script>

    <!-- Preloader: mostra só na 1ª visita da sessão. Marca html.is-loaded antes
         do paint para não piscar a camada nas navegações internas. -->
    <script is:inline>
      try {
        if (sessionStorage.getItem('ottoSeen')) {
          document.documentElement.classList.add('is-loaded');
        } else {
          sessionStorage.setItem('ottoSeen', '1');
        }
      } catch (e) {}
    </script>

    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Otto Branding" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Preload das fontes above-the-fold: corpo (Inter 400) e display (Pogonia).
         As demais (500/700, Black) carregam sob demanda via font-display: swap. -->
    <link rel="preload" href="/fonts/inter/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/pogonia/Pogonia-Black.woff2" as="font" type="font/woff2" crossorigin />

    <title>{title}</title>
  </head>
  <body>
    <Preloader />
    <div id="top"></div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <FloatingActions />

    <script>
      // Reveal de seções: fade + slide ao entrar na viewport.
      // Se não houver IntersectionObserver ou houver redução de movimento,
      // tudo já aparece visível (o CSS de reduced-motion também garante isso).
      const targets = document.querySelectorAll<HTMLElement>('.reveal');
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reduced || !('IntersectionObserver' in window) || targets.length === 0) {
        targets.forEach((el) => el.classList.add('is-visible'));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.05, rootMargin: '0px 0px -12% 0px' }
        );
        targets.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
